# Public site URL used for metadata, canonical URLs, and integrations.
NEXT_PUBLIC_SITE_URL=https://redclaycap.com

# Server-only lead capture settings. Do not expose these with NEXT_PUBLIC_.
# Use a Zapier/Make/n8n/CRM webhook, custom API endpoint, or backend lead database endpoint.
LEAD_CAPTURE_WEBHOOK_URL=
LEAD_CAPTURE_WEBHOOK_SECRET=

# Optional future production integrations.
EMAIL_NOTIFICATION_WEBHOOK_URL=
CRM_WEBHOOK_URL=
GOOGLE_MAPS_API_KEY=

# Public analytics placeholders. Safe to expose in browser bundles.
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_GTM_ID=
NEXT_PUBLIC_GOOGLE_ADS_ID=
NEXT_PUBLIC_META_PIXEL_ID=
