{
  "framework": "nextjs",
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/property-review",
      "destination": "/#get-my-cash-offer",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        }
      ]
    }
  ]
}
